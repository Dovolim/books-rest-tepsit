<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
             http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>it.edu.marconipontedera.tepsit</groupId>
  <artifactId>books-rest-client</artifactId>
  <version>0.0.1-SNAPSHOT</version>
  <packaging>jar</packaging>

  <name>TEPSIT - Books REST Client</name>
  <url>https://github.com/kismet/teaching/tree/main/tepsit</url>

  <developers>
    <developer>
      <name>Stefano Lenzi</name>
      <roles><role>Docente</role></roles>
      <organization>ITI "G.Marconi" di Pontedera, Italy</organization>
      <organizationUrl>https://www.marconipontedera.edu.it/</organizationUrl>
    </developer>
  </developers>

  <description>
    Progetto client JAX-RS separato dal server. Dimostra come interrogare
    i servizi REST del books-rest-server usando Jersey Client API.
    Basato sulla lezione 6 della guida html.it di Francesco Cioffi.
  </description>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <maven.compiler.source>8</maven.compiler.source>
    <maven.compiler.target>8</maven.compiler.target>
  </properties>

  <dependencies>
    <!-- Jersey Client - come da lezione 6 della guida html.it -->
    <dependency>
      <groupId>org.glassfish.jersey.core</groupId>
      <artifactId>jersey-client</artifactId>
      <version>2.23.2</version>
    </dependency>
    <dependency>
      <groupId>org.glassfish.jersey.media</groupId>
      <artifactId>jersey-media-moxy</artifactId>
      <version>2.23.2</version>
    </dependency>

    <!-- Gson per parsing JSON delle risposte -->
    <dependency>
      <groupId>com.google.code.gson</groupId>
      <artifactId>gson</artifactId>
      <version>2.10.1</version>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-jar-plugin</artifactId>
        <version>3.3.0</version>
        <configuration>
          <archive>
            <manifest>
              <mainClass>it.edu.marconipontedera.tepsit.client.BooksClient</mainClass>
            </manifest>
          </archive>
        </configuration>
      </plugin>
      <!-- Plugin per creare un jar eseguibile con tutte le dipendenze -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-assembly-plugin</artifactId>
        <version>3.6.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals><goal>single</goal></goals>
            <configuration>
              <archive>
                <manifest>
                  <mainClass>it.edu.marconipontedera.tepsit.client.BooksClient</mainClass>
                </manifest>
              </archive>
              <descriptorRefs>
                <descriptorRef>jar-with-dependencies</descriptorRef>
              </descriptorRefs>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
